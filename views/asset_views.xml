<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 1. The Wizard View (Must come before the action/form) -->
    <record id="view_asset_copy_wizard_form" model="ir.ui.view">
        <field name="name">asset.copy.wizard.form</field>
        <field name="model">asset.copy.wizard</field>
        <field name="arch" type="xml">
            <form string="Copy Asset Details">
                <group>
                    <field name="asset_id" options="{'no_create': True}"/>
                </group>
                <footer>
                    <button string="Copy Information" name="action_copy_data" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- 2. The Action to open the Wizard -->
    <record id="action_asset_copy_wizard" model="ir.actions.act_window">
        <field name="name">Copy from Asset</field>
        <field name="res_model">asset.copy.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- 3. Search View -->
    <record id="view_asset_asset_search" model="ir.ui.view">
        <field name="name">asset.asset.search</field>
        <field name="model">asset.asset</field>
        <field name="arch" type="xml">
            <search string="Search Assets">
                <field name="name"/>
                <field name="serialnumber"/>
                <field name="employee_barcode"/>
                <field name="employee_id"/>
                <field name="model"/>
                <filter name="assigned" string="Assigned" domain="[('status', '=', 'assigned')]"/>
                <filter name="available" string="Available" domain="[('status', '=', 'available')]"/>
            </search>
        </field>
    </record>

    <!-- 4. Tree (List) View -->
    <record id="view_asset_asset_tree" model="ir.ui.view">
        <field name="name">asset.asset.tree</field>
        <field name="model">asset.asset</field>
        <field name="arch" type="xml">
            <list>
                
               

                <field name="first_image_id" 
                                widget="image" 
                                options="{'size': [90, 90], 'preview_image': 'datas'}" 
                                string="Image"/>


                <field name="name"/>
                <field name="serialnumber"/>
                <field name="type_id"/>
                <field name="employee_id"/>
                <field name="status" widget="badge" decoration-info="status == 'assigned'"/>
                <field name="value" sum="Total Value"/>
                <field name="acquisition_date" optional="show"/>
                <field name="subtype_id" optional="show"/>
                <field name="style_id" optional="show"/>
                <field name="shape_id" optional="show"/> 
                <field name="employee_barcode" optional="show"/>
                <field name="department_id" optional="show"/>
                <field name="location_id" optional="show"/>
                <field name="image_url" optional="show"/>
            </list>
        </field>
    </record>

    <!-- 5. Main Form View -->
    <record id="view_asset_asset_form" model="ir.ui.view">
        <field name="name">asset.asset.form</field>
        <field name="model">asset.asset</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_view_qr_label_html" string="View QR Label (HTML)" type="object" class="btn-primary"/>
                    
                    <!-- The Copy Button -->
                    <button name="%(action_asset_copy_wizard)d" 
                            string="Copy from Asset" 
                            type="action" 
                            class="oe_highlight"
                            invisible="not id"/>

                    <field name="status" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <field name="qr_image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Asset Name"/></h1>
                    </div>
                    <group>
                        <group string="Basic Info">
                            <field name="model"/>
                            <field name="serialnumber"/>
                            <field name="type_id"/>
                            <field name="subtype_id"/>
                            <field name="style_id"/>
                            <field name="shape_id"/>
                            <field name="vendor_id"/>
                        </group>
                        <group string="Assignment">
                            <field name="employee_id"/>
                            <field name="department_id"/>
                            <field name="location_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Details">
                            <group>
                                <field name="value"/>
                                <field name="acquisition_date"/>
                                <field name="purchase_order"/>
                                <field name="invoice"/>
                                <field name="color"/>
                                <field name="dimension"/>
                                <field name="qr_code" widget="url" readonly="1"/>
                                <field name="description"/>
                            </group>
                        </page>
                        <page string="Photos">
                            <field name="image_ids" widget="many2many_binary"/>
                        </page>


                        <page string="History">
                            <field name="history_ids">
                                <list editable="bottom" delete="0" create="0">
                                    <field name="employee_id"   readonly="1"/>
                                    <field name="received_date" readonly="1"/>
                                    <field name="returned_date" readonly="1"/>

                                    
                                    
                                    <field name="receiver_signature" widget="signature" optional="show" readonly="receiver_signature != False" force_save="1"/>







                                    <field name="note"/>
                                </list>
                            </field>
                        </page>


                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- 6. Main Action and Menus -->
    <record id="action_asset_asset" model="ir.actions.act_window">
        <field name="name">Assets</field>
        <field name="res_model">asset.asset</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_qr_assets_root" name="QR Assets" web_icon="qr_assets,static/description/icon.png"/>
    <menuitem id="menu_assets_main"    name="Management" parent="menu_qr_assets_root"/>
    <menuitem id="menu_asset_list"     name="Assets" parent="menu_assets_main" action="action_asset_asset"/>




</odoo>